{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/manojmallick/sigmap-codex-bridge/schemas/benchmark-pack-v1.schema.json",
  "title": "SigMap Codex Bridge benchmark pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_schema_version",
    "pack_id",
    "evidence_kind",
    "repository",
    "tasks",
    "environment",
    "runner",
    "schemas"
  ],
  "properties": {
    "pack_schema_version": { "const": 1 },
    "pack_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$" },
    "evidence_kind": { "enum": ["original", "replication"] },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "revision", "license", "public"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "pattern": "^[0-9a-fA-F]{40,64}$" },
        "license": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9.+-]{1,63}$" },
        "public": { "type": "boolean" }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "platforms", "setup_command"],
      "properties": {
        "python": { "type": "string", "minLength": 1 },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["darwin", "linux"] }
        },
        "setup_command": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/command" }
          ]
        }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repetitions", "sandbox", "start_condition"],
      "properties": {
        "repetitions": { "type": "integer", "minimum": 1 },
        "sandbox": { "enum": ["read-only", "workspace-write", "danger-full-access"] },
        "start_condition": { "enum": ["raw", "sigmap"] }
      }
    },
    "schemas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "artifact", "report"],
      "properties": {
        "task": { "const": 1 },
        "artifact": { "const": 1 },
        "report": { "const": 1 }
      }
    }
  },
  "$defs": {
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
