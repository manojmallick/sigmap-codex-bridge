{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/manojmallick/sigmap-codex-bridge/schemas/benchmark-task-v1.schema.json",
  "title": "SigMap Codex Bridge benchmark task v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "revision",
    "prompt",
    "expected_behavior",
    "test_command"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string", "minLength": 1 },
    "expected_behavior": { "type": "string", "minLength": 1 },
    "setup_command": { "$ref": "#/$defs/command" },
    "test_command": { "$ref": "#/$defs/command" },
    "static_check_commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/command" }
    },
    "allowed_files": { "$ref": "#/$defs/uniqueStrings" },
    "expected_files": { "$ref": "#/$defs/uniqueStrings" },
    "expected_symbols": { "$ref": "#/$defs/uniqueStrings" },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "repetitions": { "type": "integer", "minimum": 1 }
  },
  "$defs": {
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "uniqueStrings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
